# DEV operational secrets — PLACEHOLDER TEMPLATE (issue #4, ADR 0007).
#
# This *.example file is committed in CLEAR but contains ONLY throwaway placeholders.
# Copy it to `services.sops.yaml`, fill throwaway dev values, then `sops -e -i` it.
# `dev` uses generated, throwaway, NON-sensitive credentials and synthetic data only —
# never real patient data, never a real production credential.
#
# SOPS encrypts EVERY value here except `env` (see /.sops.yaml `unencrypted_regex`), so a
# new secret key is never left in clear by accident. Operational secrets ONLY — no patient
# key material.
env: dev

postgres:
  app_password: REPLACE_ME_dev_throwaway
  replication_password: REPLACE_ME_dev_throwaway
  admin_password: REPLACE_ME_dev_throwaway

minio:
  root_key: REPLACE_ME_dev_throwaway
  root_secret: REPLACE_ME_dev_throwaway
  service_key: REPLACE_ME_dev_throwaway
  service_secret: REPLACE_ME_dev_throwaway

# Signs short-TTL presigned media URLs (#23). Operational secret, NOT a patient key.
presigned_url_signing_key: REPLACE_ME_dev_throwaway

backup_encryption_key: REPLACE_ME_dev_throwaway

# TLS is usually terminated by a local proxy in dev; values left empty on purpose.
tls:
  cert: ""
  key: ""
