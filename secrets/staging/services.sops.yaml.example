# STAGING operational secrets — PLACEHOLDER TEMPLATE (issue #4, ADR 0007).
#
# This *.example file is committed in CLEAR but contains ONLY placeholders. The REAL bundle
# (`services.sops.yaml`) is created and encrypted by an in-country operator at bootstrap and
# committed ONLY in encrypted form. The staging age private key lives in-country only.
#
# Residency: staging is in-country (ARTCI / loi n°2013-450, ADR 0005). Operational secrets
# ONLY — no patient master keys / per-record data keys / QR session keys, ever.
env: staging

postgres:
  app_password: REPLACE_AT_BOOTSTRAP
  replication_password: REPLACE_AT_BOOTSTRAP
  admin_password: REPLACE_AT_BOOTSTRAP

minio:
  root_key: REPLACE_AT_BOOTSTRAP
  root_secret: REPLACE_AT_BOOTSTRAP
  service_key: REPLACE_AT_BOOTSTRAP
  service_secret: REPLACE_AT_BOOTSTRAP

# Signs short-TTL presigned media URLs (#23). Operational secret, NOT a patient key.
presigned_url_signing_key: REPLACE_AT_BOOTSTRAP

backup_encryption_key: REPLACE_AT_BOOTSTRAP

# Caddy/TLS reverse proxy. CA strategy deferred to #8 (ACME vs in-country CA).
tls:
  cert: REPLACE_AT_BOOTSTRAP
  key: REPLACE_AT_BOOTSTRAP
