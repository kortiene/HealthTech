# HealthTech — LOCAL DEV environment template (ADR 0007, #4).
#
# Copy to `.env` (gitignored) for local development:  cp .env.example .env
# These are THROWAWAY, NON-sensitive dev values that match the local `just dev-up`
# stack (infra/dev/compose.yaml). NEVER put a real secret here — `.env` is
# gitignored, but `.env.example` is committed and must contain placeholders only.
#
# staging/prod NEVER read this file: their secrets are injected from the SOPS/age
# vault (secrets/<env>/services.sops.yaml) by the IaC — see secrets/README.md.

# --- Backend operational config (read by backend/src/config.rs) -------------
APP_ENV=dev
BIND_ADDR=0.0.0.0:8080
DATABASE_URL=postgres://healthtech:dev_throwaway_pg@localhost:5432/healthtech
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=dev_minio_root
MINIO_SECRET_KEY=dev_throwaway_minio
PRESIGNED_URL_SIGNING_KEY=dev_throwaway_presign_key

# --- Local dev stack (read by infra/dev/compose.yaml) -----------------------
POSTGRES_USER=healthtech
POSTGRES_PASSWORD=dev_throwaway_pg
POSTGRES_DB=healthtech
POSTGRES_PORT=5432
MINIO_ROOT_USER=dev_minio_root
MINIO_ROOT_PASSWORD=dev_throwaway_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
