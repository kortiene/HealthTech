# Dependencies
node_modules/

# Build output
dist/
build/

# Rust
target/
**/*.rs.bk

# Flutter / Dart (app-patient)
app-patient/.dart_tool/
app-patient/.flutter-plugins
app-patient/.flutter-plugins-dependencies
app-patient/build/
app-patient/android/.gradle/
app-patient/android/local.properties
.packages
*.iml

# Terraform (infra)
infra/**/.terraform/
infra/**/*.tfstate*

# Secrets / local env — NEVER commit (ADR 0007 / #4)
.env
.env.*
*.pem
*.key
# …but DO commit the placeholder templates (no real values in them).
!.env.example
!*.env.example

# SOPS/age: never commit private keys or decrypted output. Encrypted bundles
# (secrets/**/*.sops.yaml) and public recipients (.sops.yaml) ARE committed.
*.agekey
**/age*.txt
*.dec
*.decrypted
secrets/**/*.plain.*
# Runtime secret dumps written by the IaC (decrypted EnvironmentFiles).
/run/
**/run/healthtech/

# ADW run workspaces / state (per-run, not source)
agents/

# Test / tooling caches
.pytest_cache/
__pycache__/
*.tsbuildinfo
.vitest/

# OS / editor
.DS_Store
*.swp
